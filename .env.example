# RestoSync Docker Compose example.
# Copy this file to .env for local/VPS testing and replace every secret value.

MYSQL_DATABASE=restosync_db
MYSQL_USER=restosync
MYSQL_PASSWORD=change_me_mysql_password
MYSQL_ROOT_PASSWORD=change_me_mysql_root_password
MYSQL_PORT=3307

BACKEND_PORT=8080
FRONTEND_PORT=4173

SPRING_PROFILES_ACTIVE=prod
# Use "always" only for the first demo/test boot if schema.sql and data.sql must seed data.
# After the database is populated, switch this to "never" to avoid accidental re-seeding.
SPRING_SQL_INIT_MODE=always
SPRINGDOC_ENABLED=false

JWT_SECRET=change-this-to-a-random-secret-with-at-least-32-characters-for-restosync
JWT_EXPIRATION=86400000

APP_CORS_ALLOWED_ORIGINS=http://localhost:4173,http://127.0.0.1:4173
APP_WS_ALLOWED_ORIGINS=http://localhost:4173,http://127.0.0.1:4173

VITE_API_BASE_URL=http://localhost:8080/api
VITE_WS_URL=http://localhost:8080/ws
